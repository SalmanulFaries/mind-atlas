    {
      "parameters": {
        "jsCode": "const message = $input.first().json.message;\nconst text = message?.text || \"\";\nconst chatId = message?.chat?.id;\n\nconst urlRegex = /(https?:\\/\\/[^\\s]+)/g;\nconst urls = text.match(urlRegex);\n\nconst url = urls ? urls[0] : null;\nconst rawText = url ? text.replace(url, \"\").trim() : text;\n\n// Heuristic: if text without URL is longer than 60 characters\n// treat the whole message as text, not a URL capture\nconst isUrlOnly = url && rawText.length < 600;\n\nreturn [{\n  json: {\n    url: isUrlOnly ? url : null,\n    raw_text: text,\n    chat_id: chatId,\n    has_url: isUrlOnly\n  }\n}];"
      },
