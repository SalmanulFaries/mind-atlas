      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst rawText = response.choices?.[0]?.message?.content || \"{}\";\nconst cleaned = rawText.replace(/```json|```/g, \"\").trim();\n\nconst jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\nconst jsonString = jsonMatch ? jsonMatch[0] : \"{}\";\n\nlet parsed = {};\ntry {\n  parsed = JSON.parse(jsonString);\n} catch(e) {\n  parsed = {\n    title: \"Untitled\",\n    summary: \"\",\n    tags: [],\n    content_type: \"\"\n  };\n}\n\n// Handle both Jina branch and microlink branch\nlet titleFallback, url, source;\n\ntry {\n  titleFallback = $('Code10').first().json.title;\n  url = $('Code10').first().json.url;\n  source = $('Code10').first().json.source;\n} catch(e) {\n  titleFallback = $('Code1').first().json.title;\n  url = $('Code1').first().json.url;\n  source = $('Code1').first().json.source;\n}\n\nreturn [{\n  json: {\n    title: parsed.title || titleFallback,\n    summary: parsed.summary || \"\",\n    tags: parsed.tags || [],\n    content_type: parsed.content_type || \"\",\n    url: url,\n    source: source,\n    chat_id: $('Code').first().json.chat_id\n  }\n}];"
      },
