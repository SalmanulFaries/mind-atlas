    {
      "parameters": {
        "jsCode": "const jinaContent = $input.first().json.data || $input.first().json.body || \"\";\nconst source = $('Code1').first().json.source;\nconst url = $('Code1').first().json.url;\nconst title = $('Code1').first().json.title;\nconst chatId = $('Code').first().json.chat_id;\n\n// Truncate to 6000 characters — sufficient for Groq context\nconst truncated = jinaContent.slice(0, 6000);\n\nreturn [{\n  json: {\n    title: title,\n    content: truncated,\n    source: source,\n    url: url,\n    chat_id: chatId\n  }\n}];"
      },
