      "parameters": {
        "jsCode": "const url = $input.first().json.data?.url || $('Code').first().json.url || \"\";\nconst title = $input.first().json.data?.title || \"Untitled\";\nconst description = $input.first().json.data?.description || \"\";\nconst publisher = $input.first().json.data?.publisher || \"\";\nconst chatId = $('Code').first().json.chat_id;\nconst originalUrl = $('Code').first().json.url;\n\nlet source = \"Article\";\nif (originalUrl.includes(\"instagram.com\")) source = \"Instagram\";\nelse if (originalUrl.includes(\"youtube.com\") || originalUrl.includes(\"youtu.be\")) source = \"YouTube\";\nelse if (originalUrl.includes(\"twitter.com\") || originalUrl.includes(\"x.com\")) source = \"X\";\nelse if (originalUrl.includes(\"whatsapp.com\")) source = \"WhatsApp\";\nelse if (originalUrl.includes(\"linkedin.com\")) source = \"LinkedIn\";\n\nreturn [{\n  json: {\n    title: title,\n    description: description,\n    publisher: publisher,\n    url: originalUrl,\n    source: source,\n    chat_id: chatId\n  }\n}];"
      },
